def extract_video_frames(path, num_frames, img_size, shuffle=False):  # Define a frame extractor with an optional temporal shuffle
    """
    Extract exactly num_frames uniformly across the video.
    If shuffle=True, the extracted indices are randomly permuted (temporal corruption).
    Returns float32 array shaped (num_frames, img_size, img_size, 3) normalized to [0,1].
    """  # Provide docstring for extraction behavior
    cap = cv2.VideoCapture(str(path))  # Open the video file for reading
    if not cap.isOpened():  # Check if the video could not be opened (missing/corrupt)
        cap.release()  # Release the capture resource
        return np.zeros((num_frames, img_size, img_size, 3), dtype=np.float32)  # Return a black video tensor fallback
    total_frames = int(cap.get(cv2.CAP_PROP_FRAME_COUNT))  # Read total number of frames from metadata
    total_frames = max(1, total_frames)  # Ensure total_frames is at least 1 to avoid invalid sampling
    indices = np.linspace(0, total_frames - 1, num_frames).astype(np.int32)  # Uniformly sample frame indices
    if shuffle:  # If temporal shuffle is requested for the pretext task
        rng = np.random.RandomState(SEED)  # Create a deterministic RNG using the global seed
        rng.shuffle(indices)  # Shuffle the indices in-place to destroy temporal order
    frames = []  # Create a Python list to store extracted frames
    for idx in indices:  # Iterate over each chosen frame index
        cap.set(cv2.CAP_PROP_POS_FRAMES, int(idx))  # Seek to the desired frame index
        ret, frame = cap.read()  # Read the frame from the video
        if ret and frame is not None:  # If the read was successful
            frame = cv2.cvtColor(frame, cv2.COLOR_BGR2RGB)  # Convert BGR (OpenCV default) to RGB
            frame = cv2.resize(frame, (img_size, img_size), interpolation=cv2.INTER_AREA)  # Resize the frame to the model input resolution
        else:  # If frame reading fails
            frame = np.zeros((img_size, img_size, 3), dtype=np.uint8)  # Use a black frame fallback
        frames.append(frame)  # Append the processed frame to the frames list
    cap.release()  # Release the video capture resource
    frames = np.stack(frames, axis=0)  # Convert list of frames into a numpy array of shape (T,H,W,C)
    return frames.astype(np.float32) / 255.0  # Normalize pixel values to [0,1] float32

