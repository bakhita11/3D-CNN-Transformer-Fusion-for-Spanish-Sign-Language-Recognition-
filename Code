def build_video_classifier(num_classes):  # Define a function that builds the 3D CNN classifier model
    """
    Compact 3D CNN baseline for spatiotemporal classification.
    For this SSL pretext, num_classes=2 (ordered vs shuffled).
    """  # Provide docstring
    inputs = layers.Input(shape=(Config.NUM_FRAMES, Config.IMG_SIZE, Config.IMG_SIZE, 3))  # Define model input shape (T,H,W,C)
    x = inputs  # Start computation graph from the input tensor
    for filters in [16, 32, 64]:  # Iterate through filter sizes for progressive feature extraction
        x = layers.Conv3D(filters, kernel_size=3, padding="same", kernel_regularizer=keras.regularizers.l2(0.01))(x)  # 3D convolution with L2 regularization
        x = layers.BatchNormalization()(x)  # Normalize activations for stable training
        x = layers.ReLU()(x)  # Apply non-linearity
        x = layers.Dropout(0.4)(x)  # Drop activations to reduce overfitting
        x = layers.MaxPool3D(pool_size=(1, 2, 2))(x)  # Pool spatially (not temporally) to preserve time resolution
    x = layers.GlobalAveragePooling3D()(x)  # Collapse spatiotemporal dimensions into a feature vector
    x = layers.Dense(256, activation="relu", kernel_regularizer=keras.regularizers.l2(0.01))(x)  # Dense layer for classification features
    x = layers.Dropout(Config.DROPOUT)(x)  # Apply configurable dropout
    x = layers.Dense(128, activation="relu")(x)  # Add a second dense layer
    x = layers.Dropout(0.3)(x)  # Apply additional dropout
    outputs = layers.Dense(num_classes, activation="softmax")(x)  # Output layer with softmax over 2 classes
    return keras.Model(inputs=inputs, outputs=outputs, name="SignaMed_TemporalBinary_3DCNN")  # Create and return the Keras model

# =============================================================================
# STEP 9: MODEL COMPILATION AND TRAINING (CLEAN OUTPUT, NO EARLY STOP, 30 EPOCHS)
# =============================================================================
print("PHASE 5: Building and training 3D CNN binary temporal classifier...")  # Announce training phase in logs

model = build_video_classifier(num_classes)  # Build the model instance
model.summary(line_length=120)  # Print the model architecture summary

optimizer = keras.optimizers.AdamW(learning_rate=Config.LR, weight_decay=Config.WEIGHT_DECAY, clipnorm=1.0)  # Create an AdamW optimizer with weight decay and gradient clipping

# IMPORTANT: keep only the metrics you want to print (train/val acc+loss only)
model.compile(  # Compile the model with optimizer, loss, and metrics
    optimizer=optimizer,  # Set optimizer for gradient updates
    loss="sparse_categorical_crossentropy",  # Use sparse categorical loss because labels are integer class IDs
    metrics=["accuracy"]  # Track only accuracy (loss is always tracked automatically)
)  # End model.compile

steps_per_epoch = max(1, int(np.ceil(len(tr_paths) / Config.BATCH_SIZE)))  # Compute steps per epoch (must be >= 1)
val_steps = max(1, int(np.ceil(len(va_paths) / Config.BATCH_SIZE)))  # Compute validation steps (must be >= 1)

class CleanEpochLogger(keras.callbacks.Callback):  # Define a callback to print a clean one-line summary per epoch
    def on_train_begin(self, logs=None):  # Define what to do when training begins
        print("epoch,train_acc,train_loss,val_acc,val_loss")  # Print a clean CSV header line
    def on_epoch_end(self, epoch, logs=None):  # Define what to do at the end of each epoch
        logs = logs or {}  # Ensure logs is a dictionary even if None
        train_acc = logs.get("accuracy", float("nan"))  # Read training accuracy from logs
        train_loss = logs.get("loss", float("nan"))  # Read training loss from logs
        val_acc = logs.get("val_accuracy", float("nan"))  # Read validation accuracy from logs
        val_loss = logs.get("val_loss", float("nan"))  # Read validation loss from logs
        print(f"{epoch+1},{train_acc:.4f},{train_loss:.4f},{val_acc:.4f},{val_loss:.4f}")  # Print one clean line for this epoch

callbacks = [  # Define callbacks (NO EarlyStopping)
    CleanEpochLogger(),  # Print clean epoch summaries only
    keras.callbacks.ModelCheckpoint("signamed_temporal_best.keras", monitor="val_accuracy", mode="max", save_best_only=True, verbose=0),  # Save best checkpoint silently
    keras.callbacks.ReduceLROnPlateau(monitor="val_loss", factor=0.5, patience=4, min_lr=1e-6, verbose=0),  # Reduce LR silently
    keras.callbacks.TerminateOnNaN()  # Terminate training if NaNs occur
]  # End callbacks list

print("Starting training...")  # Log training start

history = model.fit(  # Start model training
    train_ds,  # Training dataset pipeline
    validation_data=val_ds,  # Validation dataset pipeline
    epochs=Config.EPOCHS,  # Exactly 30 epochs (no early stopping)
    steps_per_epoch=steps_per_epoch,  # Steps per epoch because dataset repeats infinitely
    validation_steps=val_steps,  # Validation steps for finite validation evaluation
    callbacks=callbacks,  # Attach callbacks
    verbose=0  # Disable Keras progress bar for clean output
)  # End model.fit

