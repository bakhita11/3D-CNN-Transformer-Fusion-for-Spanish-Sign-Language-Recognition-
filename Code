def make_binary_labels(paths):  # Define a function to double dataset and create binary labels for temporal order task
    """
    For each video:
    - original order -> label 0
    - shuffled order -> label 1
    Dataset size doubles (2N).
    """  # Provide docstring
    new_paths = []  # Create an output list of paths duplicated per video
    new_labels = []  # Create an output list of labels (0 or 1)
    for p in paths:  # Iterate over each path
        new_paths.append(p)  # Add original sample (same path)
        new_labels.append(0)  # Label 0 means keep temporal order
        new_paths.append(p)  # Add corrupted sample (same path, but loader will shuffle frames)
        new_labels.append(1)  # Label 1 means shuffle temporal order
    return np.array(new_paths), np.array(new_labels, dtype=np.int32)  # Return duplicated paths and int32 labels

