def find_filename_column(df):  # Define a helper that guesses which column stores filenames in a split CSV
    """
    Official split CSVs sometimes use different column names.
    This function tries common candidates and returns the first match.
    """  # Provide docstring
    candidates = ["FILENAME", "filename", "file", "video", "VIDEO", "name", "NOMBRE"]  # List common candidate column names
    for c in candidates:  # Iterate over candidates in order
        if c in df.columns:  # If the candidate exists in the dataframe columns
            return c  # Return the first column that matches
    return None  # If no match is found, return None

def load_splits_robust(data_root, rgb_paths):  # Define a function that loads official splits or creates fallback random splits
    """
    Loads official splits if present (CSV files inside ANNOTATIONS/).
    If splits are missing or unreadable, creates a reproducible random 80/10/10 split.
    Split dataframes will be returned with a unified column named 'FILENAME'.
    """  # Provide docstring
    ann_dir = os.path.join(data_root, "ANNOTATIONS")  # Build path to ANNOTATIONS directory
    csv_files = sorted(glob.glob(os.path.join(ann_dir, "*.csv")))  # Find all CSV files in ANNOTATIONS and sort

    use_official = False  # Flag indicating whether we successfully loaded official splits
    tr_df = va_df = te_df = None  # Initialize split dataframes

    if len(csv_files) >= 3:  # Only attempt official splits if at least 3 CSV files exist
        try:  # Start a try block to safely parse official split files
            tr_df0 = pd.read_csv(csv_files[0])  # Read the first CSV as train split candidate
            va_df0 = pd.read_csv(csv_files[1])  # Read the second CSV as validation split candidate
            te_df0 = pd.read_csv(csv_files[2])  # Read the third CSV as test split candidate
            tr_col = find_filename_column(tr_df0)  # Detect filename column in train split
            va_col = find_filename_column(va_df0)  # Detect filename column in validation split
            te_col = find_filename_column(te_df0)  # Detect filename column in test split
            if tr_col is None or va_col is None or te_col is None:  # If any split is missing a recognizable filename column
                raise ValueError("Official split CSVs missing a recognizable filename column")  # Raise an error so we fallback
            tr_df = pd.DataFrame({"FILENAME": tr_df0[tr_col].astype(str).tolist()})  # Normalize train split into a standard FILENAME column
            va_df = pd.DataFrame({"FILENAME": va_df0[va_col].astype(str).tolist()})  # Normalize val split into a standard FILENAME column
            te_df = pd.DataFrame({"FILENAME": te_df0[te_col].astype(str).tolist()})  # Normalize test split into a standard FILENAME column
            use_official = True  # Mark that we will use official splits
            print("Using official splits from ANNOTATIONS/")  # Log that official splits are active
        except Exception as e:  # Catch any errors from loading official splits
            print("Official splits failed, switching to random split:", e)  # Log the failure and reason

    if not use_official:  # If we could not use official splits, build random deterministic splits
        print("Using reproducible random 80/10/10 split")  # Log fallback split logic
        indices = np.arange(len(rgb_paths))  # Create an index list over all videos
        np.random.RandomState(SEED).shuffle(indices)  # Shuffle indices deterministically
        split_tr = int(0.8 * len(indices))  # Compute the train cutoff index
        split_va = int(0.9 * len(indices))  # Compute the validation cutoff index
        tr_df = pd.DataFrame({"FILENAME": [os.path.basename(rgb_paths[i]) for i in indices[:split_tr]]})  # Create train dataframe of filenames
        va_df = pd.DataFrame({"FILENAME": [os.path.basename(rgb_paths[i]) for i in indices[split_tr:split_va]]})  # Create validation dataframe of filenames
        te_df = pd.DataFrame({"FILENAME": [os.path.basename(rgb_paths[i]) for i in indices[split_va:]]})  # Create test dataframe of filenames

    print("Split sizes: train/val/test =", len(tr_df), len(va_df), len(te_df))  # Print the sizes of the chosen splits
    return tr_df, va_df, te_df  # Return the three split dataframes

