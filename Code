def _py_load_video_for_task(path_tensor, label_tensor):  # Define the Python-side loader used by tf.py_function
    """
    Python function executed by tf.py_function.
    If label==1, frames are temporally shuffled.
    """  # Provide docstring
    p = path_tensor  # Start with the path tensor input
    if hasattr(p, "numpy"):  # If it is an eager tensor, convert to numpy
        p = p.numpy()  # Convert to numpy
    if isinstance(p, np.ndarray):  # If it is wrapped as a numpy array
        p = p.item()  # Extract the scalar element
    if isinstance(p, bytes):  # If it is bytes
        p = p.decode("utf-8")  # Decode bytes to string
    p = str(p)  # Ensure path is a Python string
    y = label_tensor  # Start with the label tensor input
    if hasattr(y, "numpy"):  # If it is an eager tensor
        y = y.numpy()  # Convert to numpy
    if isinstance(y, np.ndarray):  # If it is wrapped as a numpy array
        y = y.item()  # Extract scalar element
    y = int(y)  # Convert label to Python integer
    shuffle = (y == 1)  # Determine whether to shuffle frames based on label
    return extract_video_frames(p, Config.NUM_FRAMES, Config.IMG_SIZE, shuffle=shuffle)  # Extract frames with optional temporal shuffle

def load_video_tf(path, label):  # Define a TensorFlow wrapper around the Python loader
    """
    Converts a file path to a video tensor inside the TF pipeline.
    Label controls whether frames are shuffled (binary temporal task).
    Returns label as scalar int32 for sparse loss/metrics.
    """  # Provide docstring
    video = tf.py_function(  # Use tf.py_function so we can call Python/OpenCV code inside tf.data pipeline
        func=_py_load_video_for_task,  # The Python function to execute
        inp=[path, label],  # Inputs are (path, label) so label determines shuffling
        Tout=tf.float32  # Output dtype is float32 video tensor
    )  # End tf.py_function
    video.set_shape([Config.NUM_FRAMES, Config.IMG_SIZE, Config.IMG_SIZE, 3])  # Set static shape so Keras knows tensor dimensions
    return video, tf.cast(label, tf.int32)  # Return video tensor and int32 label

@tf.function  # Compile augmentation to run in TensorFlow graph mode for speed
def augment_frames(video, label):  # Define augmentation function for videos
    """
    Applies augmentation on video tensor.
    Kept moderate so the temporal task remains meaningful.
    """  # Provide docstring
    if tf.random.uniform(()) < 0.7:  # Randomly decide whether to flip horizontally
        video = tf.image.flip_left_right(video)  # Flip each frame horizontally
    video = tf.image.random_brightness(video, max_delta=0.2)  # Apply random brightness jitter
    video = tf.image.random_contrast(video, lower=0.8, upper=1.2)  # Apply random contrast jitter
    return tf.clip_by_value(video, 0.0, 1.0), label  # Clip valid range and return unchanged label

def make_video_dataset(paths, labels, training=True):  # Define function to create a tf.data pipeline
    """
    Builds a tf.data pipeline.
    - Paths are tf.string tensors
    - Labels are int32 (0 or 1)
    - Shuffle buffer is never 0
    """  # Provide docstring
    paths = paths.astype(str)  # Ensure NumPy array of paths is string type
    labels = labels.astype(np.int32)  # Ensure labels are int32 for TensorFlow
    ds = tf.data.Dataset.from_tensor_slices((paths, labels))  # Create a dataset of (path,label) pairs
    if training:  # If training pipeline
        buffer_size = int(min(256, len(paths)))  # Choose a shuffle buffer capped at 256
        buffer_size = max(1, buffer_size)  # Ensure buffer is never 0 to avoid InvalidArgumentError
        ds = ds.shuffle(buffer_size=buffer_size, seed=SEED, reshuffle_each_iteration=True)  # Shuffle dataset order each epoch
        ds = ds.repeat()  # Repeat indefinitely so we can define steps_per_epoch manually
    ds = ds.map(load_video_tf, num_parallel_calls=tf.data.AUTOTUNE)  # Map each path to extracted frames in parallel
    if training:  # If training pipeline
        ds = ds.map(augment_frames, num_parallel_calls=tf.data.AUTOTUNE)  # Apply augmentations in parallel
    ds = ds.batch(Config.BATCH_SIZE)  # Group examples into batches
    ds = ds.prefetch(tf.data.AUTOTUNE)  # Prefetch batches to overlap CPU preprocessing with GPU training
    return ds  # Return the final dataset pipeline

