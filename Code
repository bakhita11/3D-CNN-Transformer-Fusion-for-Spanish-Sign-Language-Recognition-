def normalize_key(name):  # Define a helper function that turns any filename-like string into a canonical key
    """
    Normalizes any filename-like token into a consistent key for lookups.
    Examples:
      'recABC' -> 'recABC'
      'recABC.mp4' -> 'recABC'
      '/path/to/recABC.mp4' -> 'recABC'
    """  # Provide docstring describing the normalization logic
    name = str(name).strip().replace("\\", "/")  # Convert to string, trim whitespace, and normalize Windows slashes
    name = os.path.basename(name)  # Strip off directory components to keep only the filename
    name = os.path.splitext(name)[0]  # Remove file extension to get base id (e.g., recXYZ)
    return name  # Return the normalized base id

if annotations_df is not None and ("FILENAME" in annotations_df.columns) and ("LABEL" in annotations_df.columns):  # Ensure dataframe exists and contains expected columns
