def create_final_paths(split_df):  # Define a function that turns split dataframes into arrays of full video paths
    """
    Converts a split dataframe into:
      - paths: array of full mp4 paths
    This uses normalized keys so split entries can be 'recX', 'recX.mp4', or full paths.
    """  # Provide docstring
    paths = []  # Initialize list of resolved full paths
    missing_video = 0  # Count how many entries could not be matched to actual mp4 files
    if "FILENAME" not in split_df.columns:  # Ensure the split dataframe includes a filename column
        raise ValueError("Split dataframe is missing required column: FILENAME")  # Stop if the column is missing
    for raw in split_df["FILENAME"].values:  # Iterate over every filename in the split
        key = normalize_key(raw)  # Normalize the entry into a canonical key
        full_path = basename_to_path.get(key, None)  # Lookup the full video path for this key
        if full_path is None:  # If no mp4 path exists for this key
            missing_video += 1  # Increment missing counter
            continue  # Skip this sample
        paths.append(full_path)  # Append the resolved mp4 path to the output list
    paths = np.array(paths)  # Convert Python list into a NumPy array
    print("Rows in split:", len(split_df))  # Print total rows in the split
    print("Matched videos:", len(paths))  # Print successfully matched videos
    print("Unmatched videos:", missing_video)  # Print unmatched count
    return paths  # Return the matched mp4 paths

